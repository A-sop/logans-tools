# logans.tools — Phase 1 (no secrets required for static site)
# Copy to .env.local when needed. Never commit .env.local

# Optional: canonical URL for sitemap, robots, OG (default: https://logans.tools)
# NEXT_PUBLIC_SITE_URL=https://logans.tools

# Landing page URL for screenshot:landing script (default: https://cm.logans.tools)
# LANDING_PAGE_URL=https://cm.logans.tools

# --- DABOS (Path B: Postgres on ln02, Ollama on ln01) ---
# DATABASE_URL=postgresql://dabos:pass@100.127.110.57:5432/dabos?sslmode=disable
# OLLAMA_BASE_URL=http://100.95.141.16:11434/v1
# OLLAMA_MODEL=llama3.2
# OPENAI_API_KEY=sk-...          # tier-2 Research when DABOS_RESEARCH_TIER=2 or task.research_tier=2
# DABOS_RESEARCH_TIER=1          # 1=Ollama (default), 2=OpenAI
# DABOS_OPENAI_MODEL=gpt-4o-mini

# --- DABOS auth (Clerk + Gmail allowlist) ---
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# CLERK_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dabos
# DABOS_ALLOWED_EMAILS=logan.d.williams@gmail.com
