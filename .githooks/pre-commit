#!/bin/sh
# Security gate — runs pre-commit framework (Semgrep, detect-secrets, Bandit, npm audit).
# SSOT: DABOS/contrib/pre-commit/pre-commit
# Enable with: git config core.hooksPath .githooks

set -e

if ! command -v pre-commit >/dev/null 2>&1; then
  echo "pre-commit not installed. Run: python -m pip install pre-commit"
  echo "Then: DABOS/scripts/install-pre-commit.ps1 (or npm run precommit:install in app repos)"
  exit 1
fi

echo "Running pre-commit security checks..."
pre-commit run --hook-stage pre-commit "$@"
